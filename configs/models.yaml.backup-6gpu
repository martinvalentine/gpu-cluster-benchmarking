# ============================================================
# Model Download & Endpoint Configuration
# ============================================================
# Single source of truth for:
#   1. Which models to download (download-models.py)
#   2. Which endpoints to route through LiteLLM proxy (gen-litellm-config.py)
#   3. Which servers to start (start-all-tmux.sh)
#   4. Per-model benchmark settings (bench-models.sh)
#
# TARGET: 6× NVIDIA A40 48GB (288GB total VRAM) + 300GB RAM
#
# Usage:
#   uv run python scripts/download-models.py                         # Download all enabled
#   uv run python scripts/download-models.py --only qwen32b-awq     # Download specific
#   uv run python scripts/download-models.py --phase p0 p1           # Download by phase
#   uv run python scripts/download-models.py --dry-run               # Preview
#   uv run python scripts/gen-litellm-config.py                      # Regenerate proxy config
#
# Models organized by benchmark phase:
#   P0 Ultra-Light:  0.6B  (~0.2 GB VRAM)
#   P1 Light:        7B    (~3 GB VRAM)
#   P2 Medium:       14B   (~5 GB VRAM)
#   P3 Heavy:        32B   (~20 GB VRAM with AWQ)
#
# Cluster config:
#   Adjust `cluster` section to match your pod's GPU count and memory.
#   Per-model vllm_tp/vllm_gpu_mem override cluster defaults.
#   Models requiring more GPUs than cluster.gpu_count are auto-skipped.
# ============================================================

# ── Cluster Configuration (6× NVIDIA A40) ─────────────────────
# gpu_count: auto-detected from nvidia-smi if set to 0 or omitted.
cluster:
  gpu_count: 6              # 6× A40 GPUs

  # vLLM optimized for 6×A40 (CUDA graphs, PagedAttention)
  # Reference: https://docs.vllm.ai/en/latest/serving/engine_args.html
  vllm:
    tp: 6                   # 6×A40 tensor parallel for large models
    gpu_mem_util: "0.92"    # 92% VRAM (A40 48GB → ~44GB usable, ~4GB buffer)
    max_model_len: 4096     # Context window per request
    max_num_seqs: 512       # High concurrency with 6 GPUs
    max_batched_tokens: 16384  # Larger chunks for 6-GPU throughput
    quant: none             # Per-model override (awq for 32B)
    block_size: 16          # PagedAttention block size (16 = best throughput)
    dtype: auto             # auto → bfloat16 on A40 (best perf)
    swap_space: 16          # 16GB CPU KV overflow — shows latency degradation curve instead of hard drops
    enforce_eager: false    # false = CUDA graphs (faster on A40)
    distributed_executor: mp  # mp = multiprocessing (faster than ray for TP)

  # llama.cpp turboquant optimized for 6×A40 (CUDA, Flash Attention, TurboQuant KV)
  # Reference: third_party/llama-cpp-turboquant/README.md
  # tensor_split: comma-separated ratios for multi-GPU (e.g. "1,1,1,1,1,1" for 6 GPUs)
  #   Omit or empty = single GPU (default). Set "1,1,1,1,1,1" for equal 6-GPU split.
  llamacpp:
    n_parallel: 16          # 16 concurrent slots (6 GPUs available)
    ctx_size: 8192          # 8K context per slot
    n_gpu_layers: all       # Offload ALL layers to GPU (A40 = 64 layers)
    tensor_split: ""        # Empty = single GPU (llama.cpp default). Set per-model below.
    batch: 4096             # Prefill batch size (larger for 6 GPUs)
    ubatch: 1024            # Micro-batch size (scaled for 6 GPUs)
    threads: 32             # CPU threads (scaled for 6 GPU setup)
    cache_key: q8_0         # 8-bit key cache (standard)
    cache_val: turbo4       # TurboQuant 4-bit value cache (~50% VRAM savings)
    flash_attn: on          # Flash Attention (required for TurboQuant)
    cache_prompt: true      # Prompt caching (reuse KV for same prefix)

# Benchmark dataset path
dataset:
  sharegpt: /workspace/datasets/sharegpt.json

# Base directory for all models
base_dir: models

# Default backend ports (used by gen-litellm-config.py)
ports:
  vllm: 8000
  llamacpp: 8001
  sglang: 8002
  embedding: 8003
  proxy: 4000

models:
  # ── Embedding Model (for LiteLLM semantic cache) ────────────
  - name: qwen3-embedding
    repo_id: Qwen/Qwen3-Embedding-0.6B-GGUF
    local_dir: gguf/qwen3-embedding-0.6b
    format: gguf
    include: "*Q8_0.gguf"
    enabled: true
    phase: embedding
    backend: llamacpp
    proxy_name: embedding-model
    endpoint: true
    api_port: 8003           # Embedding server port (overrides backend default)

  # ── Phase P0: Ultra-Light (0.5B) ───────────────────────────
  # Small model → TP=1, minimal GPU usage, high concurrency
  - name: qwen0.5b
    repo_id: Qwen/Qwen2.5-0.5B-Instruct
    local_dir: hf/qwen2.5-0.6b
    format: hf
    enabled: true
    phase: p0
    backend: vllm
    proxy_name: qwen0.5b-vllm
    endpoint: true
    vllm_tp: 1              # 1 GPU is enough for 0.5B
    vllm_gpu_mem: "0.40"    # ~19GB reserved — 0.5B weights ~1GB, rest for KV cache headroom
    vllm_max_seqs: 512      # High concurrency (tiny model, plenty of VRAM)

  - name: qwen0.5b-gguf
    repo_id: Qwen/Qwen2.5-0.5B-Instruct-GGUF
    local_dir: gguf/qwen2.5-0.6b
    format: gguf
    include: "*q4_k_m.gguf"
    enabled: true
    phase: p0
    backend: llamacpp
    proxy_name: qwen0.5b-llamacpp
    endpoint: true
    llamacpp_n_parallel: 32     # 32 slots — tiny model (~300MB), single GPU, 128K total ctx
    llamacpp_ctx_size: 4096     # 4K context

  # ── Phase P1: Light (7B) ───────────────────────────────────
  # Mid-size → TP=1, moderate GPU usage, high concurrency
  - name: llama3.1-8b
    repo_id: meta-llama/Llama-3.1-8B-Instruct
    local_dir: hf/llama3.1-8b
    format: hf
    enabled: false
    phase: p1
    backend: vllm
    proxy_name: llama3.1-8b-vllm
    endpoint: true
    vllm_tp: 1              # 1 GPU fits 8B BF16
    vllm_gpu_mem: "0.85"    # ~40GB reserved
    vllm_max_seqs: 256      # High concurrency (7B on 48GB is comfortable)
    # NOTE: Requires Meta approval. Run: hf auth login

  - name: qwen7b
    repo_id: Qwen/Qwen2.5-7B-Instruct
    local_dir: hf/qwen2.5-7b
    format: hf
    enabled: true
    phase: p1
    backend: vllm
    proxy_name: qwen7b-vllm
    endpoint: true
    vllm_tp: 1              # 1 GPU fits 7B BF16
    vllm_gpu_mem: "0.92"    # 92% VRAM (~44GB usable)
    vllm_max_seqs: 128      # Realistic for 7B BF16 at 4K ctx on single GPU

  - name: qwen7b-gguf
    repo_id: Qwen/Qwen2.5-7B-Instruct-GGUF
    local_dir: gguf/qwen2.5-7b
    format: gguf
    include: "*q4_k_m*"
    enabled: true
    phase: p1
    backend: llamacpp
    proxy_name: qwen7b-llamacpp
    endpoint: true
    llamacpp_n_parallel: 16     # 16 slots — single GPU, watch VRAM with turbo4 KV cache
    llamacpp_ctx_size: 8192     # 8K context

  # ── Phase P2: Medium (14B) ─────────────────────────────────
  # Large → TP=2 for KV cache headroom (14B BF16=28GB, 2×48GB = plenty of room)
  - name: qwen14b
    repo_id: Qwen/Qwen2.5-14B-Instruct
    local_dir: hf/qwen2.5-14b
    format: hf
    enabled: false
    phase: p2
    backend: vllm
    proxy_name: qwen14b-vllm
    endpoint: true
    vllm_tp: 2              # 2 GPUs — 14B BF16 ~28GB split across 2×48GB, extra KV cache headroom
    vllm_gpu_mem: "0.92"    # 92% per GPU
    vllm_max_seqs: 256      # Moderate concurrency (plenty of VRAM with TP=2)

  - name: qwen14b-gguf
    repo_id: Qwen/Qwen2.5-14B-Instruct-GGUF
    local_dir: gguf/qwen2.5-14b
    format: gguf
    include: "*q4_k_m*"
    enabled: true
    phase: p2
    backend: llamacpp
    proxy_name: qwen14b-llamacpp
    endpoint: true
    llamacpp_n_parallel: 8      # 8 slots — single GPU, borderline VRAM (~8GB weights + 8×8192 KV). Reduce to 4 if OOM
    llamacpp_ctx_size: 8192     # 8K context

  # ── Phase P3: Heavy (32B BF16) ─────────────────────────────
  # Largest → TP=6, full BF16 (6×48GB = 288GB, no quantization needed)
  - name: qwen32b
    repo_id: Qwen/Qwen2.5-32B-Instruct
    local_dir: hf/qwen2.5-32b
    format: hf
    enabled: true
    phase: p3
    backend: vllm
    proxy_name: qwen32b-vllm
    endpoint: true
    # 32B BF16 ≈ 64GB → split across 6×48GB GPUs via TP=6
    # Full precision = best quality, plenty of VRAM with 6 GPUs
    vllm_tp: 6              # 6×A40 tensor parallel for large models
    vllm_gpu_mem: "0.92"    # 92% VRAM (~44GB per GPU)
    vllm_max_seqs: 128      # Realistic for 32B at 8K ctx on 6×44GB (~1TB KV would be needed for 512)
    vllm_max_batched_tokens: 32768  # 128 seqs × 256 tokens/step prefill chunk — prevents artificial TTFT inflation
    # Override cluster max_model_len: 6 GPUs × 44GB = 264GB KV budget, push to 8K
    vllm_max_model_len: 8192

  - name: qwen32b-gguf
    repo_id: Qwen/Qwen2.5-32B-Instruct-GGUF
    local_dir: gguf/qwen2.5-32b
    format: gguf
    include: "qwen2.5-32b-instruct-q4_k_m*"
    enabled: true
    phase: p3
    backend: llamacpp
    proxy_name: qwen32b-llamacpp
    endpoint: true
    llamacpp_n_parallel: 8      # 8 parallel slots (6 GPUs with tensor-split)
    llamacpp_tensor_split: "1,1,1,1,1,1"  # Equal split across 6×A40
    llamacpp_ctx_size: 8192     # 8K context per slot
    llamacpp_batch: 4096        # Larger prefill batch for 6 GPUs
    llamacpp_ubatch: 1024       # Larger micro-batch for 6 GPUs
    llamacpp_threads: 32        # More CPU threads for 6 GPU setup
    llamacpp_cache_key: q8_0    # 8-bit key cache
    llamacpp_cache_val: turbo4  # TurboQuant 4-bit value cache
    llamacpp_flash_attn: on     # Flash Attention (required for TurboQuant)
    llamacpp_cache_prompt: true # Prompt caching for prefix reuse
