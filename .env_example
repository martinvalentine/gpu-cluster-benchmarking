# ============================================================
# Environment Variables — Copy to .env and customize
# ============================================================
# cp .env_example .env
#
# Orchestrator scripts (bench-models.sh, start-all-tmux.sh)
# read from configs/models.yaml — .env is for individual scripts only.
#
# Scripts fail with a clear error if required vars are missing.
# ============================================================

# ── Model Paths (required for individual scripts) ──────────────
# VLLM_MODEL=/workspace/models/hf/qwen2.5-32b-awq
# LLAMA_MODEL=/workspace/models/gguf/qwen2.5-32b/qwen2.5-32b-instruct-q4_k_m-00001-of-00005.gguf

# ── vLLM Settings ─────────────────────────────────────────────
# VLLM_PORT=8000
# VLLM_HOST=0.0.0.0
# VLLM_TP=1
# VLLM_GPU_MEM_UTIL=0.87
# VLLM_QUANT=none
# VLLM_MAX_MODEL_LEN=4096
# VLLM_MAX_NUM_SEQS=64

# ── llama.cpp Settings ────────────────────────────────────────
# LLAMA_PORT=8001
# LLAMA_HOST=0.0.0.0
# LLAMA_N_PARALLEL=4
# LLAMA_CTX_SIZE=4096
# LLAMA_CACHE_KEY=q8_0
# LLAMA_CACHE_VAL=turbo4
# LLAMA_FLASH_ATTN=on

# ── SGLang Settings ───────────────────────────────────────────
# SGLANG_PORT=8002
# SGLANG_TP=1
# SGLANG_QUANT=none

# ── Benchmark Settings ────────────────────────────────────────
# VLLM_BENCH_MODEL=/workspace/models/hf/qwen2.5-32b-awq
# VLLM_BENCH_URL=http://localhost:8000
# VLLM_BENCH_DATASET_PATH=/workspace/datasets/sharegpt.json
# SGLANG_BENCH_MODEL=/workspace/models/hf/qwen2.5-32b-awq
# SGLANG_BENCH_URL=http://localhost:8002
# LLAMA_BENCH_URL=http://localhost:8001/v1

# ── Redis ─────────────────────────────────────────────────────
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── LiteLLM Proxy ─────────────────────────────────────────────
# LITELLM_PORT=4000
