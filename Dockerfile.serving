# ============================================================
# LLM Serving Base Image — vLLM + llama-cpp-turboquant
# ============================================================
#
# Uses official vLLM image as base — no need to build from source.
# llama-cpp-turboquant is built from the submodule.
#
# Build:
#   docker build -f Dockerfile.serving -t llm-serving:latest .
#
# Run:
#   docker run --gpus all -it llm-serving:latest
#
# Usage:
#   vllm serve <model>
#   llama-server -m <model.gguf>   (turboquant binary on port 8001)
# ============================================================

ARG VLLM_VERSION=v0.22.1
ARG CUDA_VERSION=129
ARG UBUNTU_VERSION=2404

# ── STAGE 1: Build llama-cpp-turboquant ──────────────────────
FROM nvidia/cuda:12.6.1-devel-ubuntu22.04 AS turboquant-build

ARG CUDA_ARCH=8.6
ARG CMAKE_JOBS=8

RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake build-essential git \
    && rm -rf /var/lib/apt/lists/*

# CUDA stubs for linking without host driver
ENV LIBRARY_PATH=/usr/local/cuda/targets/x86_64-linux/lib/stubs:${LIBRARY_PATH}
ENV LD_LIBRARY_PATH=/usr/local/cuda/targets/x86_64-linux/lib/stubs:${LD_LIBRARY_PATH}
RUN ln -sf /usr/local/cuda/targets/x86_64-linux/lib/stubs/libcuda.so \
           /usr/local/cuda/targets/x86_64-linux/lib/stubs/libcuda.so.1

COPY third_party/llama-cpp-turboquant /src

RUN CUDA_ARCH_CMAKE="$(echo "${CUDA_ARCH}" | sed 's/\.//g; s/ /;/g')" \
    && cmake -B /build -S /src \
        -DCMAKE_BUILD_TYPE=Release \
        -DGGML_CUDA=ON \
        -DCMAKE_CUDA_ARCHITECTURES="${CUDA_ARCH_CMAKE}" \
        -DGGML_CUDA_GRAPHS=ON \
        -DLLAMA_BUILD_EXAMPLES=OFF \
        -DLLAMA_BUILD_TESTS=OFF \
    && cmake --build /build --config Release -j"${CMAKE_JOBS}"

# ── STAGE 2: Runtime ─────────────────────────────────────────
FROM vllm/vllm-openai:${VLLM_VERSION}-cu${CUDA_VERSION}-ubuntu${UBUNTU_VERSION} AS runtime

# llama-server binary + shared libs (turboquant only)
COPY --from=turboquant-build /build/bin/llama-server /usr/local/bin/llama-server
COPY --from=turboquant-build /build/bin/llama-bench  /usr/local/bin/llama-bench
COPY --from=turboquant-build /build/bin/*.so*        /usr/local/lib/
RUN ldconfig

# SSH + Redis + workspace
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssh-server redis-server \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /run/sshd /root/.ssh /workspace/{models,datasets,results,logs} \
    && chmod 700 /root/.ssh

COPY scripts/docker/start.sh /app/start.sh
RUN chmod +x /app/start.sh

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
  CMD curl -f http://localhost:8000/health || exit 1

EXPOSE 22 6379 8000 8001 8003 30000

WORKDIR /workspace

ENTRYPOINT ["/app/start.sh"]
